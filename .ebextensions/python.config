option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: coffe_shop.wsgi:application
    NumProcesses: 3
    NumThreads: 15
    StaticFiles: /static/=staticfiles/
    
commands:
  001_collectstatic:
    command: |
      source /var/app/venv/*/bin/activate
      python manage.py collectstatic --noinput --clear
    leader_only: true
    ignoreErrors: true
